# ----------------------------------------------------------------------------
# SimpleInvoice — environment variable contract
# ----------------------------------------------------------------------------
# Copy this file to `.env.local` and replace each placeholder with a real value.
# `.env.local` is git-ignored. Do NOT commit real secrets.
#
# All variables below are read server-side only — never prefix them with
# `NEXT_PUBLIC_` (that would inline them into the browser bundle).
# ----------------------------------------------------------------------------

# 101 Digital identity server (WSO2)
AUTH_CLIENT_ID=your-client-id
AUTH_CLIENT_SECRET=your-client-secret
AUTH_API_URL=https://identity.example.com/oauth2/token

# 101 Digital membership service (used to fetch /users/me)
MEMBERSHIP_API_URL=https://membership.example.com

# 101 Digital invoice service
INVOICE_API_URL=https://invoice.example.com
